# Modalita sicura senza chiamate remote.
PIXEL_BOT_DRY_RUN=1

# Backend condiviso con l'app Fatture. Compilare per usare l'AI reale.
PIXEL_BOT_AI_ENDPOINT=
PIXEL_BOT_AI_TOKEN=

# Limiti conservativi.
PIXEL_BOT_AI_TIMEOUT=45
PIXEL_BOT_MAX_HISTORY=12
PIXEL_BOT_MAX_REQUESTS=3
PIXEL_BOT_ESTIMATED_COST_PER_REQUEST=0.01
PIXEL_BOT_MAX_ESTIMATED_COST=0.05
