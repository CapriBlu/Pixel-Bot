# Modalita sicura: nessuna chiamata remota.
PIXEL_BOT_DRY_RUN=1

# OpenAI Responses API diretta. Non salvare mai la chiave nel repository.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
PIXEL_BOT_AI_PROVIDER=openai

# Facoltativo: backend personalizzato alternativo.
PIXEL_BOT_AI_ENDPOINT=
PIXEL_BOT_AI_TOKEN=

# Limiti conservativi.
PIXEL_BOT_AI_TIMEOUT=45
PIXEL_BOT_MAX_HISTORY=12
PIXEL_BOT_MAX_REQUESTS=2
PIXEL_BOT_ESTIMATED_COST_PER_REQUEST=0.01
PIXEL_BOT_MAX_ESTIMATED_COST=0.05

# Resilienza chiamate AI (numero totale massimo di tentativi)
PIXEL_BOT_AI_MAX_RETRIES=3
PIXEL_BOT_AI_RETRY_BACKOFF=1.0
